# Master server config — copy to `.env` and fill in.
# `.env` is gitignored.

# HTTP / WS port for the master Express app
MASTER_PORT=8080

# Path to the SQLite database file (relative to server/ or absolute)
DB_PATH=./data/smashkarts.db

# Where to bind the master HTTP server (use 127.0.0.1 in prod behind nginx)
MASTER_HOST=127.0.0.1

# Allowed origins for CORS (comma-separated). In dev: HTTP serve.py origin.
CORS_ORIGINS=http://localhost:8060,http://127.0.0.1:8060

# Internal token used by per-room Godot processes when posting to /api/internal/*
# Use `node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"` to generate.
INTERNAL_TOKEN=change-me-in-prod

# Path to the Godot binary that master spawns for each room.
# Dev (Windows): C:\Godot_v4.6.1-stable_win64_console.exe
# Prod (Linux):  /opt/smash-karts/server/smash-karts-server.x86_64
GODOT_BIN=C:\Godot_v4.6.1-stable_win64_console.exe

# Per-room Godot port range (master allocates from this pool)
PORT_POOL_START=4445
PORT_POOL_SIZE=100

# Healthcheck poller (seconds)
HEALTHCHECK_INTERVAL_S=5
HEALTHCHECK_TIMEOUT_S=15

# Idle room cleanup (seconds with 0 players)
IDLE_TIMEOUT_S=300

# Public base URL used in WS URLs returned to client (HTTP form; auto-converted to ws://wss://).
# Dev: http://localhost:8080  | Prod: https://play.example.com
PUBLIC_BASE_URL=http://localhost:8080

# Optional explicit ws/wss base. If omitted, master derives from PUBLIC_BASE_URL.
# Dev: ws://localhost:8080  | Prod: wss://play.example.com
PUBLIC_WS_BASE_URL=

# Public client URL used in invite_link (?join=CODE).
# Dev: http://localhost:8060  | Prod: https://play.example.com
PUBLIC_CLIENT_URL=http://localhost:8060

# Path to the Godot project directory (master uses this when --path is needed for dev runs).
# Prod: not used — exported binary embeds project.
GODOT_PROJECT_PATH=

# Set to "1" in dev to enable verbose logging and use the dev Godot binary.
DEV_MODE=1
