# Godot 4+ specific ignores
.godot/

# Godot-specific ignores
.import/
export.cfg

# Imported translations (automatically generated from CSV files)
*.translation

# Mono-specific ignores
.mono/
data_*/
mono_crash.*.json

# Build outputs — exclude generated artifacts, keep structure files
build/web/*
!build/web/.gitkeep
build/server/*
!build/server/.gitkeep
# Legacy root-level build artifacts (old export path)
build/index.*
dist/
*.exe
*.pck
*.zip

# System/Editor-specific
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# Credentials & secrets
.godot/export_credentials.cfg

# Custom
.firecrawl/

# Master server (Node.js)
server/node_modules/
server/.env
server/data/*.db
server/data/*.db-shm
server/data/*.db-wal
server/data/*.sqlite
server/data/*.sqlite-shm
server/data/*.sqlite-wal

# Raw Kenney source pack (full archive; committed subset lives in assets/map_materials/space-kit/)
assets-full-data/

# Windows bash crash dumps
bash.exe.stackdump
*.stackdump
