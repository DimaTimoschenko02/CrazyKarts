# Production master.env — install at /etc/smash-karts/master.env
# (referenced by smash-master.service via EnvironmentFile=)
# chmod 600; owner = the user running the service.

MASTER_HOST=127.0.0.1
MASTER_PORT=8080

# SQLite file lives in the working dir's ./data/ unless overridden.
DB_PATH=/opt/smash-karts/server/data/smashkarts.db

# CORS origins for browser clients. In prod: only your TLS origin.
CORS_ORIGINS=https://play.example.com

# 32+ random bytes — generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
INTERNAL_TOKEN=REPLACE_ME_RANDOM_HEX

# Path to the Godot Linux server binary that master spawns per room.
GODOT_BIN=/opt/smash-karts/server/smash-karts-server.x86_64

# Per-room port pool (kept on 127.0.0.1, never exposed in firewall).
PORT_POOL_START=4445
PORT_POOL_SIZE=100

# Healthcheck poller (seconds).
HEALTHCHECK_INTERVAL_S=5
HEALTHCHECK_TIMEOUT_S=15

# Idle room cleanup (seconds with 0 players).
IDLE_TIMEOUT_S=300

# Public URLs returned to clients.
PUBLIC_BASE_URL=https://play.example.com
PUBLIC_WS_BASE_URL=wss://play.example.com
PUBLIC_CLIENT_URL=https://play.example.com

# Production: leave empty (binary embeds project).
GODOT_PROJECT_PATH=

# DO NOT set DEV_MODE=1 in prod.
DEV_MODE=
