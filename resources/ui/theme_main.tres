[gd_resource type="Theme" load_steps=22 format=3 uid="uid://theme_main_01"]

; Neon Stadium theme. Base font_size=18; buttons 22 (~68px tall); thick 2-3px
; saturated borders; dramatic 32px shadows. RoomCard variation gives compact rows.

